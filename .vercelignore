packages/app-store/intercom/static/*.png
packages/app-store/facetime/static/*.png
packages/app-store/salesroom/static/*.png
packages/app-store/salesroom/static/*.jpeg

# TypeScript build info (regenerated on build)
**/*.tsbuildinfo

# Test and e2e files
