# =============================================================================
# SLOTLY BILLING ENV VARS
# =============================================================================
# Two billing flows:
#   Flow 1 — Stripe Connect: client pays service pro at booking
#   Flow 2 — Lemon Squeezy: pro pays Slotly SaaS subscription ($9/mo)
# =============================================================================

# ─── FLOW 1: STRIPE CONNECT (booking payments) ───────────────────────────────
# Get from: https://dashboard.stripe.com/test/apikeys  (test mode)
#           https://dashboard.stripe.com/apikeys       (live mode)

# Stripe secret key (server-only, NEVER expose to browser)
STRIPE_PRIVATE_KEY=sk_test_REPLACE_ME

# Stripe publishable key (safe for browser)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_REPLACE_ME

# Stripe Connect platform client ID
# Get from: https://dashboard.stripe.com/settings/connect  → Platform settings
STRIPE_CLIENT_ID=ca_REPLACE_ME

# Webhook secret for booking payment events
# Get by running: stripe listen --forward-to localhost:3000/api/integrations/stripepayment/webhook
# Or from: https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Webhook secret for app-level Stripe events
STRIPE_WEBHOOK_SECRET_APPS=whsec_REPLACE_ME

# Webhook secret for Stripe billing events (if using Stripe for org billing)
STRIPE_WEBHOOK_SECRET_BILLING=whsec_REPLACE_ME

# ─── FLOW 2: LEMON SQUEEZY (SaaS subscription $9/mo) ────────────────────────
# Sign up free at: https://app.lemonsqueezy.com
# No monthly fee — takes 5% + $0.50 per transaction

# API key from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=REPLACE_ME

# Store ID from: https://app.lemonsqueezy.com/settings/stores
LEMONSQUEEZY_STORE_ID=REPLACE_ME

# Product ID after creating a "Slotly Pro" product ($9/mo subscription)
LEMONSQUEEZY_PRODUCT_ID=REPLACE_ME

# Variant ID for the $9/month price point
LEMONSQUEEZY_VARIANT_ID_MONTHLY=REPLACE_ME

# Webhook signing secret from: https://app.lemonsqueezy.com/settings/webhooks
# Webhook URL to register: https://your-domain.com/api/lemonsqueezy/webhook
# Events to subscribe: subscription_created, subscription_updated, subscription_cancelled, subscription_expired
LEMONSQUEEZY_WEBHOOK_SECRET=REPLACE_ME
